      <div class="fr-dim-chip-counts"><span class="fr-dim-chip-count c-ship">ship</span></div>
    </div>
  </div>

  <!-- Fixed findings history -->
  <div class="fr-findings-header">
    <span class="fr-findings-title">Fixed this run (2)</span>
  </div>

  <div class="fr-history-note">
    All 2 findings were fixed in commit <code>5a0433f</code> during the review fix loop. 0 open findings remain. Verdict: Ship.
  </div>

  <div class="fr-finding-row">
    <span class="fr-finding-badge badge-fixed">fixed</span>
    <div class="fr-finding-body">
      <div class="fr-finding-id">AC-1 · MED · Accessibility + Frontend-Accessibility</div>
      <div class="fr-finding-msg"><code>aria-pressed</code> removed from quiz option buttons — incorrect toggle semantics for a single-selection quiz</div>
      <div class="fr-finding-loc">src/components/quiz/QuizView.tsx:210</div>
      <div class="fr-finding-commit">fixed-at: 5a0433f</div>
    </div>
  </div>

  <div class="fr-finding-row">
    <span class="fr-finding-badge badge-fixed">fixed</span>
    <div class="fr-finding-body">
      <div class="fr-finding-id">CR-1 · LOW · Correctness</div>
      <div class="fr-finding-msg">Non-null assertion on <code>restoredAttempt</code> replaced with explicit null guard (<code>if (!attempt) return null</code>)</div>
      <div class="fr-finding-loc">src/components/quiz/QuizView.tsx:110</div>
      <div class="fr-finding-commit">fixed-at: 5a0433f</div>
