    </div>
    <div class="fr-dim-chip">
      <span class="fr-dim-chip-name">frontend-perf</span>
      <div class="fr-dim-chip-counts"><span class="fr-dim-chip-count c-ship">ship</span></div>
    </div>
    <div class="fr-dim-chip">
      <span class="fr-dim-chip-name">interface-craft</span>
      <div class="fr-dim-chip-counts"><span class="fr-dim-chip-count c-ship">ship</span></div>
    </div>
    <div class="fr-dim-chip">
      <span class="fr-dim-chip-name">ux-copy</span>
      <div class="fr-dim-chip-counts"><span class="fr-dim-chip-count c-ship">ship</span></div>
    </div>
    <div class="fr-dim-chip">
      <span class="fr-dim-chip-name">testing</span>
      <div class="fr-dim-chip-counts"><span class="fr-dim-chip-count c-ship">ship</span></div>
