<section class="fragment-review-master" data-artifact="review" data-rev="1">
<style>
.fragment-review-master { font-family: system-ui, sans-serif; max-width: 720px; }
.rm-header { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
.rm-verdict { padding: 4px 14px; border-radius: 16px; font-size: 13px; font-weight: 700; letter-spacing: .04em; background: #16a34a; color: #fff; }
.rm-pills { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 12px; }
.rm-pill { padding: 3px 10px; border-radius: 12px; font-size: 12px; font-weight: 600; border: 1px solid currentColor; }
.rm-pill-clean { color: #16a34a; border-color: #16a34a; }
.rm-pill-low { color: #b45309; border-color: #b45309; }
.rm-pill-nit { color: #6b7280; border-color: #6b7280; }
.rm-pill-fixed { color: #0369a1; border-color: #0369a1; }
.rm-section { margin-bottom: 14px; }
.rm-section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; opacity: .55; margin-bottom: 6px; }
.rm-finding { margin-bottom: 8px; padding: 8px 10px; border-left: 3px solid currentColor; border-radius: 4px; }
.rm-finding-fixed { color: #0369a1; background: rgba(3,105,161,0.05); }
.rm-finding-low { color: #b45309; background: rgba(180,83,9,0.05); }
.rm-finding-nit { color: #6b7280; background: rgba(107,114,128,0.05); }
.rm-finding-title { font-weight: 600; font-size: 13px; margin-bottom: 3px; }
.rm-finding-loc { font-size: 11px; opacity: .65; font-family: monospace; }
.rm-badge { display: inline-block; padding: 1px 6px; border-radius: 4px; font-size: 11px; color: white; margin-right: 4px; }
.rm-badge-med { background: #0369a1; }
.rm-badge-low { background: #b45309; }
.rm-badge-nit { background: #6b7280; }
.rm-dim-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 4px; margin-bottom: 12px; }
.rm-dim-chip { padding: 4px 8px; border-radius: 6px; font-size: 11px; background: rgba(22,163,74,0.08); border: 1px solid rgba(22,163,74,0.25); color: #15803d; }
.rm-dim-chip-issues { background: rgba(107,114,128,0.07); border-color: rgba(107,114,128,0.25); color: #4b5563; }
</style>
