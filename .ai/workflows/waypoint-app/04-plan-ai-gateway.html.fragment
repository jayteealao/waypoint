<section class="fragment-plan" data-artifact="plan" data-slice="ai-gateway" data-rev="0">

  <style>
    .fragment-plan .files-touched {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.875rem;
      margin-bottom: 1.5rem;
    }
    .fragment-plan .files-touched th,
    .fragment-plan .files-touched td {
      padding: 0.5rem 0.75rem;
      border-bottom: 1px solid var(--color-border, #e5e7eb);
      text-align: left;
    }
    .fragment-plan .files-touched th {
      font-weight: 600;
      background: var(--color-surface-raised, #f9fafb);
    }
    .fragment-plan .pl-status-new    { color: #16a34a; font-weight: 600; }
    .fragment-plan .pl-status-modified { color: #d97706; font-weight: 600; }
    .fragment-plan .pl-delta-pos { color: #16a34a; }
    .fragment-plan .pl-delta-neg { color: #dc2626; }
    .fragment-plan .pl-module-tag {
      display: inline-block;
      padding: 0.125rem 0.5rem;
      border-radius: 9999px;
      font-size: 0.75rem;
      background: var(--color-surface-raised, #f3f4f6);
      color: var(--color-text-secondary, #6b7280);
    }
    .fragment-plan .pl-expand-btn {
      background: none;
      border: none;
      cursor: pointer;
      color: var(--color-accent, #b45309);
      font-size: 0.75rem;
      padding: 0;
    }
    .fragment-plan .pl-change-detail {
      display: none;
      padding: 0.5rem 0.75rem;
      background: var(--color-surface, #fafafa);
      font-size: 0.8125rem;
      color: var(--color-text-secondary, #6b7280);
      border-bottom: 1px solid var(--color-border, #e5e7eb);
    }
    .fragment-plan .pl-change-detail.open { display: table-row; }
    .fragment-plan .callout-risk,
    .fragment-plan .callout-warn {
      margin-bottom: 1rem;
      padding: 0.875rem 1rem;
      border-left: 4px solid;
      border-radius: 0 0.375rem 0.375rem 0;
    }
    .fragment-plan .callout-risk {
      border-color: #dc2626;
      background: #fef2f2;
      color: #7f1d1d;
    }
    .fragment-plan .callout-warn {
      border-color: #d97706;
      background: #fffbeb;
      color: #78350f;
    }
    .fragment-plan .callout-risk strong,
    .fragment-plan .callout-warn strong {
      display: block;
      margin-bottom: 0.25rem;
      font-weight: 600;
    }
    @media (prefers-color-scheme: dark) {
      .fragment-plan .files-touched th { background: #1f2937; }
      .fragment-plan .files-touched th,
      .fragment-plan .files-touched td { border-color: #374151; }
      .fragment-plan .pl-module-tag { background: #374151; color: #9ca3af; }
      .fragment-plan .pl-change-detail { background: #111827; color: #9ca3af; border-color: #374151; }
      .fragment-plan .callout-risk { background: #450a0a; color: #fca5a5; border-color: #ef4444; }
      .fragment-plan .callout-warn { background: #451a03; color: #fcd34d; border-color: #f59e0b; }
    }
    :root[data-theme="light"] .fragment-plan .files-touched th { background: #f9fafb; }
    :root[data-theme="dark"]  .fragment-plan .files-touched th { background: #1f2937; }
  </style>

  <table class="files-touched">
    <thead>
      <tr>
        <th>File</th>
        <th>Status</th>
        <th>Module</th>
        <th>Delta</th>
        <th></th>
      </tr>
    </thead>
    <tbody>

      <tr data-file="src/cloudflare-workers.d.ts">
        <td><code>src/cloudflare-workers.d.ts</code></td>
        <td class="pl-status-modified">modified</td>
        <td><span class="pl-module-tag">gateway</span></td>
        <td><span class="pl-delta-pos">+2</span></td>
        <td><button class="pl-expand-btn" aria-expanded="false">▸ details</button></td>
      </tr>
      <tr class="pl-change-detail"><td colspan="5">Add OPENROUTER_API_KEY to Cloudflare.Env interface so gateway.ts can read it via env binding.</td></tr>

      <tr data-file="src/lib/ai/tiers.ts">
        <td><code>src/lib/ai/tiers.ts</code></td>
        <td class="pl-status-new">new</td>
        <td><span class="pl-module-tag">gateway</span></td>
        <td><span class="pl-delta-pos">+60</span></td>
        <td><button class="pl-expand-btn" aria-expanded="false">▸ details</button></td>
      </tr>
      <tr class="pl-change-detail"><td colspan="5">Model tier config: GenerationType, TierConfig, and TIERS record with interview/lesson/structured/quiz entries. Fallback chains and pricing metadata per tier.</td></tr>

      <tr data-file="src/lib/ai/quota.ts">
        <td><code>src/lib/ai/quota.ts</code></td>
        <td class="pl-status-new">new</td>
        <td><span class="pl-module-tag">quota</span></td>
        <td><span class="pl-delta-pos">+80</span></td>
        <td><button class="pl-expand-btn" aria-expanded="false">▸ details</button></td>
      </tr>
      <tr class="pl-change-detail"><td colspan="5">D1-backed quota engine: checkQuota() sums cost_usd over today's UTC window. QuotaStatus return type used by gateway and UI. Default $0.50/day limit as exported constant.</td></tr>

      <tr data-file="src/lib/ai/gateway.ts">
        <td><code>src/lib/ai/gateway.ts</code></td>
        <td class="pl-status-new">new</td>
        <td><span class="pl-module-tag">gateway</span></td>
        <td><span class="pl-delta-pos">+130</span></td>
        <td><button class="pl-expand-btn" aria-expanded="false">▸ details</button></td>
      </tr>
      <tr class="pl-change-detail"><td colspan="5">Core gateway: callGateway() — quota gate, tier routing, retry/fallback loop, usage recording, 5 instrumentation signals from 04b-instrument.md. QuotaExhaustedError carries QuotaStatus.</td></tr>

      <tr data-file="src/components/quota/QuotaCard.tsx">
        <td><code>src/components/quota/QuotaCard.tsx</code></td>
        <td class="pl-status-new">new</td>
        <td><span class="pl-module-tag">ui</span></td>
        <td><span class="pl-delta-pos">+50</span></td>
        <td><button class="pl-expand-btn" aria-expanded="false">▸ details</button></td>
      </tr>
      <tr class="pl-change-detail"><td colspan="5">Warm blocking card: shows usage/limit bar and reset time. No paywall language. Composes Card.tsx + ember tokens.</td></tr>

      <tr data-file="src/styles.css">
        <td><code>src/styles.css</code></td>
        <td class="pl-status-modified">modified</td>
        <td><span class="pl-module-tag">ui</span></td>
        <td><span class="pl-delta-pos">+18</span></td>
        <td><button class="pl-expand-btn" aria-expanded="false">▸ details</button></td>
      </tr>
      <tr class="pl-change-detail"><td colspan="5">Add .quota-card, .quota-card__bar, .quota-card__reset using existing ember design tokens. Scoped; no global selector side-effects.</td></tr>

      <tr data-file="src/server/ai.ts">
        <td><code>src/server/ai.ts</code></td>
        <td class="pl-status-new">new</td>
        <td><span class="pl-module-tag">gateway</span></td>
        <td><span class="pl-delta-pos">+50</span></td>
        <td><button class="pl-expand-btn" aria-expanded="false">▸ details</button></td>
      </tr>
      <tr class="pl-change-detail"><td colspan="5">getQuotaStatus() TanStack Start server function. Mirrors journeys.ts withSession pattern. Returns QuotaStatus to fixture route and future consumers.</td></tr>

      <tr data-file="src/routes/_authenticated/quota-fixture.tsx">
        <td><code>src/routes/_authenticated/quota-fixture.tsx</code></td>
        <td class="pl-status-new">new</td>
        <td><span class="pl-module-tag">tests</span></td>
        <td><span class="pl-delta-pos">+40</span></td>
        <td><button class="pl-expand-btn" aria-expanded="false">▸ details</button></td>
      </tr>
      <tr class="pl-change-detail"><td colspan="5">Test harness route: renders QuotaCard when exhausted, "quota-ok" data-testid when not. Triggers pnpm generate-routes to update routeTree.gen.ts.</td></tr>

      <tr data-file="tests/smoke/ai-gateway.test.ts">
        <td><code>tests/smoke/ai-gateway.test.ts</code></td>
        <td class="pl-status-new">new</td>
        <td><span class="pl-module-tag">tests</span></td>
        <td><span class="pl-delta-pos">+130</span></td>
        <td><button class="pl-expand-btn" aria-expanded="false">▸ details</button></td>
      </tr>
      <tr class="pl-change-detail"><td colspan="5">8 Vitest unit tests (node env): quota gate (2), usage recording (1), fallback chain (1), tier routing (1), structured+tool-call invariant (1), cost math both paths (2).</td></tr>

      <tr data-file="tests/smoke/ai-tool-call.test.ts">
        <td><code>tests/smoke/ai-tool-call.test.ts</code></td>
        <td class="pl-status-modified">modified</td>
        <td><span class="pl-module-tag">tests</span></td>
        <td><span class="pl-delta-pos">+25</span></td>
        <td><button class="pl-expand-btn" aria-expanded="false">▸ details</button></td>
      </tr>
      <tr class="pl-change-detail"><td colspan="5">Add 3 gateway-tier live smoke tests (skipIf !OPENROUTER_API_KEY): interview, lesson, structured tiers. Extends existing skipIf pattern; no new infra.</td></tr>

    </tbody>
  </table>

  <!-- @include callout { "kind": "risk", "title": "OpenRouter usage.total_cost may be absent", "body": "If the @tanstack/ai-openrouter adapter does not expose total_cost in its usage payload, the fallback recomputation from token counts activates. Mitigated: gateway prefers total_cost and logs a warning on fallback; unit test covers both paths." } -->
  <div class="callout-risk">
    <strong>High: OpenRouter usage.total_cost may be absent</strong>
    If the <code>@tanstack/ai-openrouter</code> adapter does not expose <code>total_cost</code> in its usage payload, the fallback recomputation from token counts activates. Mitigated: gateway prefers <code>total_cost</code> and logs a warning on fallback; unit test covers both paths.
  </div>

  <!-- @include callout { "kind": "warn", "title": "Quota unit is daily cost_usd — consumer slices must not assume token counts", "body": "All four generation consumer slices will call callGateway(). Gateway returns a typed QuotaStatus; consumers never see token arithmetic. If the quota unit pivots in future, only quota.ts changes." } -->
  <div class="callout-warn">
    <strong>Medium: Quota unit is daily cost_usd — consumer slices must not assume token counts</strong>
    All four generation consumer slices call <code>callGateway()</code>. The gateway returns a typed <code>QuotaStatus</code>; consumers never see token arithmetic. If the quota unit pivots in future, only <code>quota.ts</code> changes.
  </div>

  <!-- @include callout { "kind": "warn", "title": "New route requires route-tree regeneration", "body": "Adding quota-fixture.tsx requires pnpm generate-routes to update routeTree.gen.ts. The generated file must be committed as part of this change." } -->
  <div class="callout-warn">
    <strong>Medium: New route requires route-tree regeneration</strong>
    Adding <code>quota-fixture.tsx</code> requires <code>pnpm generate-routes</code> to update <code>routeTree.gen.ts</code>. The generated file must be committed as part of this change.
  </div>

  <!-- @include fragment-ready { "name": "plan", "artifact": "plan", "detailJson": "{\"counts\":{\"files\":10,\"modules\":4,\"risks\":3}}" } -->
  <script>
    (function () {
      var section = document.currentScript.closest('.fragment-plan')

      // Expand/collapse row detail toggle
      section.querySelectorAll('.pl-expand-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var row = btn.closest('tr')
          var detail = row.nextElementSibling
          var open = detail && detail.classList.contains('open')
          if (detail) {
            detail.classList.toggle('open', !open)
            btn.setAttribute('aria-expanded', String(!open))
            btn.textContent = open ? '▸ details' : '▾ details'
          }
        })
      })

      window.dispatchEvent(new CustomEvent('sdlc:fragment-ready', {
        detail: {
          name: 'plan',
          artifact: 'plan',
          counts: { files: 10, modules: 4, risks: 3 }
        }
      }))
    })()
  </script>

</section>
