<section class="fragment-review-dimension" data-artifact="review-dimension" data-rev="1">
<style>
.rd-fa .rd-fa-note { font-size: 0.82rem; color: var(--ink-muted, #6b7280); background: var(--surface, #f9f9f9); border: 1px solid var(--border, #e5e7eb); border-radius: 8px; padding: 10px 14px; margin-bottom: 10px; }
.rd-fa .rd-fa-finding { border: 1px solid var(--border, #e5e7eb); border-radius: 8px; padding: 12px 14px; margin-bottom: 8px; border-left: 3px solid #d97706; }
