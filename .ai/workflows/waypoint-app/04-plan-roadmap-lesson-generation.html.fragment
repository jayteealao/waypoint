<section class="fragment-plan" data-artifact="plan" data-slice="roadmap-lesson-generation" data-rev="0">
  <style>
    .fragment-plan .pl-files-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; margin-top: 1rem; }
    .fragment-plan .pl-files-table th { text-align: left; padding: 0.4rem 0.6rem; background: var(--surface-2, #f4f4f4); border-bottom: 1px solid var(--border, #ddd); }
    .fragment-plan .pl-files-table td { padding: 0.35rem 0.6rem; border-bottom: 1px solid var(--border, #eee); vertical-align: top; }
    .fragment-plan .pl-status-new    { color: #2a9d2a; font-weight: 600; }
    .fragment-plan .pl-status-mod    { color: #c77c00; font-weight: 600; }
    .fragment-plan .pl-callout { border-left: 3px solid; padding: 0.6rem 0.9rem; margin: 0.8rem 0; border-radius: 0 4px 4px 0; font-size: 0.85rem; }
    .fragment-plan .pl-callout-risk  { border-color: #e53e3e; background: rgba(229,62,62,0.07); }
    .fragment-plan .pl-callout-warn  { border-color: #c77c00; background: rgba(199,124,0,0.07); }
    .fragment-plan .pl-callout-info  { border-color: #3182ce; background: rgba(49,130,206,0.07); }
    .fragment-plan .pl-callout-title { font-weight: 700; margin-bottom: 0.25rem; }
    .fragment-plan .pl-revs { margin-top: 1rem; }
    .fragment-plan .pl-revs summary { cursor: pointer; font-size: 0.8rem; color: var(--ink-muted, #666); }
    .fragment-plan details.pl-expand summary { cursor: pointer; font-size: 0.8rem; color: var(--ink-muted, #666); padding: 0.2rem 0; }
    .fragment-plan details.pl-expand pre { font-size: 0.75rem; overflow-x: auto; background: var(--surface-2,#f4f4f4); padding: 0.5rem; border-radius: 4px; }
    @media (prefers-color-scheme: dark) {
      .fragment-plan .pl-files-table th { background: var(--surface-2, #222); }
      .fragment-plan .pl-files-table td { border-color: var(--border, #333); }
      .fragment-plan details.pl-expand pre { background: var(--surface-2, #1a1a1a); }
    }
    :root[data-theme="dark"] .fragment-plan .pl-files-table th { background: var(--surface-2, #222); }
    :root[data-theme="light"] .fragment-plan .pl-files-table th { background: var(--surface-2, #f4f4f4); }
  </style>

