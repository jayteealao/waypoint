<section class="fragment-plan" data-artifact="plan" data-slice="platform-proofs" data-rev="0">
<style>
.fragment-plan { font-family: system-ui, -apple-system, sans-serif; font-size: 14px; color: var(--color-fg, #1a1a1a); }
.fragment-plan .pl-files-heading { font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; color: var(--color-fg-muted, #666); margin: 1.5rem 0 .5rem; }
.fragment-plan table.files-touched { width: 100%; border-collapse: collapse; font-size: 13px; }
.fragment-plan table.files-touched th { text-align: left; font-weight: 600; padding: 6px 10px; border-bottom: 2px solid var(--color-border, #e0e0e0); }
.fragment-plan table.files-touched td { padding: 5px 10px; border-bottom: 1px solid var(--color-border, #e0e0e0); vertical-align: top; }
.fragment-plan .chip { display: inline-block; padding: 2px 7px; border-radius: 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .03em; }
.fragment-plan .chip-new { background: #d1fae5; color: #065f46; }
.fragment-plan .chip-modified { background: #fef3c7; color: #92400e; }
.fragment-plan .chip-deleted { background: #fee2e2; color: #991b1b; }
.fragment-plan .chip-high { background: #fee2e2; color: #991b1b; }
.fragment-plan .chip-med { background: #fef3c7; color: #92400e; }
.fragment-plan .chip-low { background: #f0fdf4; color: #166534; }
.fragment-plan .callout { border-left: 4px solid #e0e0e0; padding: 10px 14px; margin: 1rem 0; border-radius: 0 6px 6px 0; }
.fragment-plan .callout-risk { border-color: #ef4444; background: #fff5f5; }
.fragment-plan .callout-warn { border-color: #f59e0b; background: #fffbeb; }
.fragment-plan .callout-info { border-color: #3b82f6; background: #eff6ff; }
.fragment-plan .callout-title { font-weight: 700; font-size: 13px; margin-bottom: 4px; }
.fragment-plan .callout-body { font-size: 13px; color: var(--color-fg-muted, #444); }
.fragment-plan details.pl-row summary { cursor: pointer; list-style: none; }
.fragment-plan details.pl-row summary::-webkit-details-marker { display: none; }
.fragment-plan .pl-diff { font-family: ui-monospace, monospace; font-size: 12px; background: var(--color-bg-subtle, #f6f8fa); padding: 10px; border-radius: 4px; margin-top: 8px; white-space: pre-wrap; }
.fragment-plan .delta-add { color: #166534; }
.fragment-plan .delta-rem { color: #991b1b; }
.fragment-plan details.pl-revs > summary { font-size: 12px; color: var(--color-fg-muted, #666); cursor: pointer; }
@media (prefers-color-scheme: dark) {
  .fragment-plan { color: #e5e7eb; }
  .fragment-plan table.files-touched th, .fragment-plan table.files-touched td { border-color: #374151; }
  .fragment-plan .chip-new { background: #064e3b; color: #6ee7b7; }
  .fragment-plan .chip-modified { background: #451a03; color: #fcd34d; }
  .fragment-plan .chip-high { background: #450a0a; color: #fca5a5; }
  .fragment-plan .chip-med { background: #451a03; color: #fcd34d; }
  .fragment-plan .chip-low { background: #052e16; color: #86efac; }
  .fragment-plan .callout-risk { background: #1f0707; border-color: #ef4444; }
  .fragment-plan .callout-warn { background: #1c1100; border-color: #f59e0b; }
  .fragment-plan .callout-info { background: #0c1a30; border-color: #3b82f6; }
  .fragment-plan .pl-diff { background: #1f2937; color: #e5e7eb; }
  .fragment-plan .callout-body { color: #9ca3af; }
}
</style>

