# ---------------------------------------------------------------------------
# OAuth providers (accounts-data-layer slice)
# Register apps at:
#   Google: https://console.developers.google.com/apis/credentials
#   GitHub:  https://github.com/settings/applications/new
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# AI gateway (ai-gateway slice)
# OpenRouter API key: https://openrouter.ai/keys
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Auth session signing (accounts-data-layer slice)
# BETTER_AUTH_SECRET: run `openssl rand -hex 32` to generate
# BETTER_AUTH_BASE_URL: the public URL of this deployment (http://localhost:3000 for dev)
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET=
BETTER_AUTH_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Cloudflare (platform-proofs / deploy)
# Account ID: Cloudflare dashboard → right sidebar
# API Token: https://dash.cloudflare.com/profile/api-tokens (needs Workers:Edit)
# ---------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
